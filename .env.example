# ============================================================
# FRONTEND — VARIABLES DE ENTORNO
# ============================================================
# Copiar este archivo como ".env" y completar los valores.
# El archivo .env NO se sube al repositorio (está en .gitignore).
#
# IMPORTANTE: Vite solo expone variables que empiecen con VITE_
# ============================================================

# ===================== DESARROLLO LOCAL =====================
# URL del backend corriendo en tu máquina local.
VITE_API_URL=http://localhost:4000/api

# ===================== RAILWAY (producción) =================
# En Railway esta variable se configura desde el DASHBOARD.
# Se documenta aquí solo como referencia.
#
# VITE_API_URL=https://tu-backend.up.railway.app/api
